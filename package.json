{
  "name": "destination-paradise",
  "private": true,
  "version": "3.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-image-manifest.mjs && node scripts/build-sitemap.mjs && vite build && node scripts/prerender.mjs",
    "build:manifest": "node scripts/build-image-manifest.mjs",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "build:prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sentry/node": "^10.63.0",
    "@sentry/react": "^10.63.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@sparticuz/chromium": "^149.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.26.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "puppeteer": "^25.1.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
